<mujoco model="simple_car">

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1"/>
    <geom name="ground" type="plane" size="30 30 0.1"/>

    <body name="car" pos="0 0 0.5">
      <freejoint/>
      <geom name="car_body" type="box" size="1 0.5 0.2"/>

      <body name="fl_wheel" pos="0.8 0.6 -0.2">
        <joint name="fl_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.2 0.1" euler="90 0 0"/>
      </body>

      <body name="fr_wheel" pos="0.8 -0.6 -0.2">
        <joint name="fr_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.2 0.1" euler="90 0 0"/>
      </body>

      <body name="rl_wheel" pos="-0.8 0.6 -0.2">
        <joint name="rl_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.2 0.1" euler="90 0 0"/>
      </body>

      <body name="rr_wheel" pos="-0.8 -0.6 -0.2">
        <joint name="rr_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.2 0.1" euler="90 0 0"/>
      </body>

    </body>
  </worldbody>

</mujoco>
